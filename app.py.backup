    def preprocess_text(self, text):
        """Advanced text preprocessing"""
        # Convert to lowercase
        text = text.lower()
        
        # Remove special characters but keep some punctuation
        text = re.sub(r'[^\w\s\.\?\!\,\@\#\$\%\&\*\(\)]', ' ', text)
        
        # Remove extra whitespace
        text = ' '.join(text.split())
        
        # Tokenize
        try:
            tokens = word_tokenize(text)
        except:
            tokens = text.split()
        
        # Remove stopwords (if language supported)
        try:
            lang = detect(text)
            if lang in self.supported_languages:
                try:
                    stop_words = set(stopwords.words(lang))
                    tokens = [t for t in tokens if t not in stop_words]
                except:
                    pass
        except:
            pass
        
        return ' '.join(tokens)
    
    def extract_features(self, text):
        """Extract advanced features from text"""
        features = {}
        
        # Basic text features
        features['length'] = len(text)
        features['word_count'] = len(text.split())
        features['avg_word_length'] = np.mean([len(w) for w in text.split()]) if text.split() else 0
        
        # Punctuation features
        features['exclamation_count'] = text.count('!')
        features['question_count'] = text.count('?')
        features['capital_ratio'] = sum(1 for c in text if c.isupper()) / len(text) if len(text) > 0 else 0
        
        # Link features
        links = self.link_pattern.findall(text)
        features['link_count'] = len(links)
        
        # Check for malicious links
        features['has_malicious_links'] = 0
        if links:
            conn = self.get_db_connection()
            cursor = conn.cursor()
            for link in links:
                try:
                    domain = urlparse(link).netloc
                    if not domain:
                        domain = link.split('/')[2] if '://' in link else link.split('/')[0]
                    domain = domain.replace('www.', '')
                    
                    # First check trusted domains whitelist
                    if any(trusted in domain for trusted in self.trusted_domains):
                        continue
                    
                    # Then check blocked domains
                    cursor.execute("SELECT threat_level FROM blocked_domains WHERE domain LIKE ?", (f'%{domain}%',))
                    if cursor.fetchone():
                        features['has_malicious_links'] = 1
                        break
                except:
                    pass
            conn.close()
        
        # Abusive pattern matching
        features['abusive_pattern_count'] = 0
        for pattern in self.abusive_patterns:
            features['abusive_pattern_count'] += len(re.findall(pattern, text.lower()))
        
        # All caps words (potential shouting)
        features['all_caps_words'] = sum(1 for word in text.split() if word.isupper() and len(word) > 2)
        
        # Repeated characters (like "aaaaaa")
        features['repeated_chars'] = len(re.findall(r'(.)\1{3,}', text))
        
        return features
    
    def train_initial_models(self):
        """Train ML models with initial data"""
        training_data = self.generate_training_data()
        
        # Prepare data for abuse detection
        texts = [d['text'] for d in training_data]
        abuse_labels = [d['is_abusive'] for d in training_data]
        spam_labels = [d['is_malicious'] for d in training_data]
        
        # Preprocess texts
        processed_texts = [self.preprocess_text(t) for t in texts]
        
        # Create TF-IDF vectorizer
        self.vectorizer = TfidfVectorizer(
            max_features=5000,
            ngram_range=(1, 3),
            min_df=2,
            max_df=0.95
        )
        
        # Transform texts
        X = self.vectorizer.fit_transform(processed_texts)
        
        # Train abuse classifier (Random Forest)
        self.abuse_classifier = RandomForestClassifier(
            n_estimators=100,
            max_depth=10,
            random_state=42
        )
        self.abuse_classifier.fit(X, abuse_labels)
        
        # Train spam/link classifier
        self.link_classifier = RandomForestClassifier(
            n_estimators=100,
            max_depth=10,
            random_state=42
        )
        self.link_classifier.fit(X, spam_labels)
        
        # Save models
        model_path = 'models/'
        os.makedirs(model_path, exist_ok=True)
        joblib.dump(self.abuse_classifier, f'{model_path}abuse_classifier.pkl')
        joblib.dump(self.link_classifier, f'{model_path}link_classifier.pkl')
        joblib.dump(self.vectorizer, f'{model_path}vectorizer.pkl')
        
        print(f"✅ ML models trained with {len(training_data)} samples")
        print(f"   • Clean comments: {len([x for x in abuse_labels if x == 0])}")
        print(f"   • Abusive comments: {sum(abuse_labels)}")
        print(f"   • Spam links: {sum(spam_labels)}")
    
    def predict_comment(self, text):
        """Use ML to predict comment classification"""
        try:
            # Preprocess text
            processed_text = self.preprocess_text(text)
            
            # Extract features
            features = self.extract_features(text)
            
            # Transform text using vectorizer
            X = self.vectorizer.transform([processed_text])
            
            # Get predictions and probabilities
            abuse_prob = self.abuse_classifier.predict_proba(X)[0]
            spam_prob = self.link_classifier.predict_proba(X)[0]
            
            # Get abuse score (probability of being abusive)
            abuse_score = abuse_prob[1] if len(abuse_prob) > 1 else 0.5
            
            # Get spam score
            spam_score = spam_prob[1] if len(spam_prob) > 1 else 0.5
            
            # Adjust based on extracted features
            if features['has_malicious_links']:
                spam_score = max(spam_score, 0.95)
            
            # ===== TRUSTED DOMAINS ADJUSTMENT =====
            if features['link_count'] > 0 and not features['has_malicious_links']:
                links = self.link_pattern.findall(text)
                all_trusted = True
                trusted_count = 0
                
                for link in links:
                    domain = urlparse(link).netloc.replace('www.', '')
                    if any(trusted in domain for trusted in self.trusted_domains):
                        trusted_count += 1
                    else:
                        shorteners = ['bit.ly', 'tinyurl.com', 'goo.gl', 'ow.ly', 'is.gd']
                        if any(shortener in domain for shortener in shorteners):
                            all_trusted = False
                            break
                        suspicious_tlds = ['.xyz', '.top', '.club', '.online', '.site', '.win', '.bid']
                        if any(domain.endswith(tld) for tld in suspicious_tlds):
                            all_trusted = False
                            break
                
                if all_trusted and trusted_count == len(links):
                    spam_score = min(spam_score, 0.2)
                    abuse_score = min(abuse_score, 0.2)
                elif trusted_count > 0:
                    spam_score = min(spam_score, 0.5)
            
            if features['abusive_pattern_count'] > 0:
                abuse_score = max(abuse_score, 0.8)
            
            # ===== ADJUSTED THRESHOLDS =====
            confidence = max(abuse_score, spam_score)
            
            if abuse_score > 0.8 or spam_score > 0.9 or features['has_malicious_links']:
                status = 'auto_rejected'
                notes = f"🔴 AUTO-REJECTED - Abuse: {abuse_score:.2f}, Spam: {spam_score:.2f}"
            elif abuse_score < 0.4 and spam_score < 0.4 and not features['has_malicious_links']:
                status = 'auto_approved'
                notes = f"🟢 AUTO-APPROVED - Abuse: {abuse_score:.2f}, Spam: {spam_score:.2f}"
            else:
                status = 'under_review'
                notes = f"🟡 UNDER REVIEW - Abuse: {abuse_score:.2f}, Spam: {spam_score:.2f}"
            
            return {
                'abuse_score': float(abuse_score),
                'spam_score': float(spam_score),
                'status': status,
                'confidence': float(confidence),
                'notes': notes,
                'features': features
            }
            
        except Exception as e:
            print(f"ML prediction error: {e}")
            return {
                'abuse_score': 0.5,
                'spam_score': 0.5,
                'status': 'under_review',
                'confidence': 0.5,
                'notes': f'⚠️ ML prediction failed: {str(e)}',
                'features': {}
            }
    
    def check_links(self, text):
        """Advanced link checking with whitelist"""
        links = self.link_pattern.findall(text)
        
        if not links:
            return {'has_links': False, 'malicious_count': 0, 'safe_count': 0, 'blocked_domains': [], 'trusted_count': 0}
        
        malicious_count = 0
        safe_count = 0
        trusted_count = 0
        blocked_domains = []
        
        conn = self.get_db_connection()
        cursor = conn.cursor()
        
        for link in links:
            try:
                domain = urlparse(link).netloc
                if not domain:
                    domain = link.split('/')[2] if '://' in link else link.split('/')[0]
                
                # Remove www. prefix if present
                domain = domain.replace('www.', '')
                
                # ===== CHECK TRUSTED DOMAINS WHITELIST FIRST =====
                if any(trusted in domain for trusted in self.trusted_domains):
                    safe_count += 1
                    trusted_count += 1
                    continue
                
                # Check against blocked domains
                cursor.execute("SELECT domain, threat_level FROM blocked_domains WHERE domain LIKE ?", (f'%{domain}%',))
                result = cursor.fetchone()
                
                if result:
                    malicious_count += 1
                    blocked_domains.append({'domain': result[0], 'threat_level': result[1]})
                else:
                    # Check if it's a suspicious TLD
                    suspicious_tlds = ['.xyz', '.top', '.club', '.online', '.site', '.win', '.bid', '.tk', '.ml', '.ga']
                    if any(domain.endswith(tld) for tld in suspicious_tlds):
                        malicious_count += 1
                        blocked_domains.append({'domain': domain, 'threat_level': 'medium'})
                    else:
                        safe_count += 1
            except:
                safe_count += 1
        
        conn.close()
        
        return {
            'has_links': True,
            'malicious_count': malicious_count,
            'safe_count': safe_count,
            'trusted_count': trusted_count,
            'total_links': len(links),
            'blocked_domains': blocked_domains
        }
    
    def add_notification(self, user_id, message, notification_type='info'):
        """Add a notification for user"""
        try:
            conn = self.get_db_connection()
            cursor = conn.cursor()
            cursor.execute('''
                INSERT INTO notifications (user_id, message, type)
                VALUES (?, ?, ?)
            ''', (user_id, message, notification_type))
            conn.commit()
            conn.close()
        except Exception as e:
            print(f"Notification error: {e}")
    
    def get_notifications(self, user_id, unread_only=False):
        """Get notifications for user"""
        try:
            conn = self.get_db_connection()
            cursor = conn.cursor()
            
            query = '''
                SELECT notification_id, message, type, is_read, created_at
                FROM notifications
                WHERE user_id = ?
            '''
            params = [user_id]
            
            if unread_only:
                query += " AND is_read = 0"
            
            query += " ORDER BY created_at DESC LIMIT 20"
            
            cursor.execute(query, params)
            rows = cursor.fetchall()
            conn.close()
            
            notifications = []
            for row in rows:
                notifications.append({
                    'id': row[0],
                    'message': row[1],
                    'type': row[2],
                    'is_read': bool(row[3]),
                    'created_at': row[4]
                })
            
            return notifications
        except Exception as e:
            print(f"Get notifications error: {e}")
            return []
    
    def mark_notifications_read(self, user_id):
        """Mark all notifications as read"""
        try:
            conn = self.get_db_connection()
            cursor = conn.cursor()
            cursor.execute('''
                UPDATE notifications SET is_read = 1
                WHERE user_id = ? AND is_read = 0
            ''', (user_id,))
            conn.commit()
            conn.close()
        except Exception as e:
            print(f"Mark read error: {e}")
    
    def register_user(self, username, password, email, full_name, phone=None, user_type='member', preferred_language='en'):
        """Register a new user"""
        conn = None
        try:
            # Input validation
            if not all([username, password, email, full_name]):
                return {"success": False, "message": "All fields are required"}
            
            if len(password) < 6:
                return {"success": False, "message": "Password must be at least 6 characters"}
            
            if not re.match(r"[^@]+@[^@]+\.[^@]+", email):
                return {"success": False, "message": "Invalid email format"}
            
            # Validate phone if provided
            country_code = None
            if phone:
                phone_validation = self.validate_phone(phone)
                if not phone_validation['valid']:
                    return {"success": False, "message": phone_validation['message']}
                phone = phone_validation['phone']
                country_code = phone_validation['country_code']
            
            conn = self.get_db_connection()
            cursor = conn.cursor()
            
            # Check for duplicates
            cursor.execute("SELECT * FROM users WHERE username = ? OR email = ?", (username, email))
            if cursor.fetchone():
                conn.close()
                return {"success": False, "message": "Username or email already exists"}
            
            # Check phone duplicate if provided
            if phone:
                cursor.execute("SELECT * FROM users WHERE phone = ?", (phone,))
                if cursor.fetchone():
                    conn.close()
                    return {"success": False, "message": "Phone number already registered"}
            
            # Insert new user
            hashed_password = self.hash_password(password)
            cursor.execute('''
                INSERT INTO users (username, password, email, full_name, phone, country_code, user_type, preferred_language)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?)
            ''', (username, hashed_password, email, full_name, phone, country_code, user_type, preferred_language))
            
            user_id = cursor.lastrowid
            conn.commit()
            
            # Add welcome notification
            welcome_message = f"Welcome {full_name}! Thank you for registering."
            self.add_notification(user_id, welcome_message, 'success')
            
            conn.close()
            
            return {
                "success": True, 
                "message": "Registration successful", 
                "user_id": user_id,
                "phone_validated": bool(phone)
            }
            
        except sqlite3.OperationalError as e:
            if conn:
                conn.close()
            if "database is locked" in str(e):
                return {"success": False, "message": "Database is busy, please try again in a moment"}
            return {"success": False, "message": f"Database error: {str(e)}"}
        except Exception as e:
            if conn:
                conn.close()
            return {"success": False, "message": f"Error: {str(e)}"}
    
    def login_user(self, username, password):
        """Login user"""
        conn = None
        try:
            if not username or not password:
                return {"success": False, "message": "Username and password required"}
            
            conn = self.get_db_connection()
            cursor = conn.cursor()
            
            cursor.execute('''
                SELECT user_id, username, password, full_name, user_type, preferred_language, is_active,
                       reputation_score, total_comments, flagged_comments, phone, country_code
                FROM users WHERE username = ? AND is_active = 1
            ''', (username,))
            
            user = cursor.fetchone()
            
            if user and self.verify_password(password, user[2]):
                # Update last login
                cursor.execute('''
                    UPDATE users SET last_login = CURRENT_TIMESTAMP 
                    WHERE user_id = ?
                ''', (user[0],))
                
                login_time = datetime.now().strftime("%Y-%m-%d %H:%M")
                welcome_back = f"Welcome back, {user[3]}! You logged in at {login_time}."
                self.add_notification(user[0], welcome_back, 'info')
                
                conn.commit()
                
                user_data = {
                    'user_id': user[0],
                    'username': user[1],
                    'full_name': user[3],
                    'user_type': user[4],
                    'preferred_language': user[5],
                    'reputation_score': user[7],
                    'total_comments': user[8],
                    'flagged_comments': user[9],
                    'phone': user[10],
                    'country_code': user[11]
                }
                
                notifications = self.get_notifications(user[0], unread_only=True)
                conn.close()
                
                return {
                    "success": True, 
                    "message": "Login successful", 
                    "user": user_data,
                    "notifications": notifications,
                    "unread_count": len(notifications)
                }
            else:
                conn.close()
                return {"success": False, "message": "Invalid username or password"}
                
        except sqlite3.OperationalError as e:
            if conn:
                conn.close()
            if "database is locked" in str(e):
                return {"success": False, "message": "Database is busy, please try again in a moment"}
            return {"success": False, "message": f"Database error: {str(e)}"}
        except Exception as e:
            if conn:
                conn.close()
            return {"success": False, "message": f"Error: {str(e)}"}
    
    def submit_comment(self, user_id, comment_text, ip_address=None, user_agent=None):
        """Submit comment with ML-based moderation"""
        conn = None
        try:
            if not comment_text or len(comment_text.strip()) < 2:
                return {"success": False, "message": "Comment must be at least 2 characters"}
            
            # Detect language
            try:
                detected_lang = detect(comment_text)
                if detected_lang not in self.supported_languages:
                    detected_lang = 'en'
            except:
                detected_lang = 'en'
            
            # Clean text for processing
            cleaned_text = self.preprocess_text(comment_text)
            
            # Check for links
            link_analysis = self.check_links(comment_text)
            
            # Get ML predictions
            ml_results = self.predict_comment(comment_text)
            
            # Combine all signals for final decision
            abuse_score = ml_results['abuse_score']
            spam_score = ml_results['spam_score']
            
            # Adjust based on link analysis
            if link_analysis['has_links']:
                if link_analysis['malicious_count'] > 0:
                    spam_score = max(spam_score, 0.95)
                    ml_results['notes'] += f" | Contains {link_analysis['malicious_count']} malicious links"
                elif link_analysis.get('trusted_count', 0) == link_analysis['total_links']:
                    spam_score = min(spam_score, 0.2)
                    abuse_score = min(abuse_score, 0.2)
                    ml_results['notes'] += f" | All links from trusted domains"
            
            # Calculate toxicity score (combined)
            toxicity_score = (abuse_score * 0.6 + spam_score * 0.4)
            
            # Determine final status with ML
            if toxicity_score > 0.8 or abuse_score > 0.8 or spam_score > 0.9 or link_analysis.get('malicious_count', 0) > 0:
                status = 'auto_rejected'
                notes = f"🔴 AUTO-REJECTED: {ml_results['notes']}"
            elif toxicity_score < 0.4 and abuse_score < 0.4 and spam_score < 0.4 and not link_analysis.get('malicious_count', 0):
                status = 'auto_approved'
                notes = f"🟢 AUTO-APPROVED: {ml_results['notes']}"
            else:
                status = 'under_review'
                notes = f"🟡 UNDER REVIEW: {ml_results['notes']}"
            
            conn = self.get_db_connection()
            cursor = conn.cursor()
            
            cursor.execute('''
                INSERT INTO comments 
                (user_id, comment_text, cleaned_text, detected_language, 
                 ml_score, abuse_score, spam_score, link_count, has_malicious_links,
                 sentiment_score, toxicity_score, status, moderation_notes, 
                 ip_address, user_agent, ml_model_version, confidence)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            ''', (
                user_id, comment_text, cleaned_text, detected_lang,
                toxicity_score, abuse_score, spam_score, 
                link_analysis.get('total_links', 0),
                link_analysis.get('malicious_count', 0) > 0,
                0.0, toxicity_score, status, notes,
                ip_address, user_agent, 'v3.2', ml_results['confidence']
            ))
            
            comment_id = cursor.lastrowid
            
            # Log the action
            cursor.execute('''
                INSERT INTO moderation_log (comment_id, action, performed_by, ml_confidence, notes)
                VALUES (?, ?, ?, ?, ?)
            ''', (comment_id, 'ml_moderated', user_id, ml_results['confidence'], notes))
            
            # Update user stats
            cursor.execute('''
                UPDATE users 
                SET total_comments = total_comments + 1,
                    flagged_comments = flagged_comments + ?
                WHERE user_id = ?
            ''', (1 if status in ['auto_rejected', 'under_review'] else 0, user_id))
            
            # Add notification for comment status
            if status == 'auto_approved':
                self.add_notification(user_id, f"Your comment #{comment_id} was auto-approved!", 'success')
            elif status == 'auto_rejected':
                self.add_notification(user_id, f"Your comment #{comment_id} was auto-rejected for inappropriate content.", 'error')
            else:
                self.add_notification(user_id, f"Your comment #{comment_id} is under review by moderators.", 'warning')
            
            conn.commit()
            conn.close()
            
            return {
                "success": True,
                "message": f"Comment processed - {status}",
                "comment_id": comment_id,
                "status": status,
                "detected_language": detected_lang,
                "ml_scores": {
                    "abuse_score": abuse_score,
                    "spam_score": spam_score,
                    "toxicity_score": toxicity_score,
                    "confidence": ml_results['confidence']
                },
                "link_analysis": link_analysis,
                "moderation_notes": notes
            }
            
        except sqlite3.OperationalError as e:
            if conn:
                conn.close()
            if "database is locked" in str(e):
                return {"success": False, "message": "Database is busy, please try again in a moment"}
            return {"success": False, "message": f"Database error: {str(e)}"}
        except Exception as e:
            if conn:
                conn.close()
            return {"success": False, "message": f"Error: {str(e)}"}
    
    def get_comments(self, user_id=None, user_type=None, status=None, limit=50):
        """Get comments with filters"""
        conn = None
        try:
            conn = self.get_db_connection()
            cursor = conn.cursor()
            
            query = '''
                SELECT c.comment_id, u.username, u.full_name, c.comment_text, 
                       c.detected_language, c.status, c.created_at, c.moderation_notes,
                       c.user_id, c.ml_score, c.abuse_score, c.spam_score, c.confidence,
                       c.link_count, c.has_malicious_links
                FROM comments c
                JOIN users u ON c.user_id = u.user_id
            '''
            
            params = []
            conditions = []
            
            if status:
                conditions.append("c.status = ?")
                params.append(status)
            
            if user_type == 'member':
                conditions.append("c.user_id = ?")
                params.append(user_id)
            
            if conditions:
                query += " WHERE " + " AND ".join(conditions)
            
            query += " ORDER BY c.created_at DESC LIMIT ?"
            params.append(limit)
            
            cursor.execute(query, params)
            rows = cursor.fetchall()
            conn.close()
            
            formatted_comments = []
            for row in rows:
                formatted_comments.append({
                    'comment_id': row[0],
                    'username': row[1],
                    'full_name': row[2],
                    'comment_text': row[3][:200] + '...' if len(row[3]) > 200 else row[3],
                    'language': row[4],
                    'status': row[5],
                    'created_at': row[6],
                    'moderation_notes': row[7],
                    'user_id': row[8],
                    'ml_scores': {
                        'overall': row[9],
                        'abuse': row[10],
                        'spam': row[11],
                        'confidence': row[12]
                    },
                    'link_count': row[13],
                    'has_malicious_links': bool(row[14])
                })
            
            return {"success": True, "comments": formatted_comments}
            
        except sqlite3.OperationalError as e:
            if conn:
                conn.close()
            if "database is locked" in str(e):
                return {"success": False, "message": "Database is busy, please try again in a moment"}
            return {"success": False, "message": f"Database error: {str(e)}"}
        except Exception as e:
            if conn:
                conn.close()
            return {"success": False, "message": f"Error: {str(e)}"}
    
    def moderate_comment(self, comment_id, admin_id, action, notes=None):
        """Admin moderation with feedback for ML model"""
        conn = None
        try:
            if action not in ['approve', 'reject']:
                return {"success": False, "message": "Invalid action"}
            
            conn = self.get_db_connection()
            cursor = conn.cursor()
            
            # Get comment details for ML feedback
            cursor.execute('''
                SELECT comment_text, ml_score, abuse_score, spam_score, status, detected_language, user_id
                FROM comments WHERE comment_id = ?
            ''', (comment_id,))
            comment = cursor.fetchone()
            
            if not comment:
                conn.close()
                return {"success": False, "message": "Comment not found"}
            
            status = 'approved' if action == 'approve' else 'rejected'
            
            # Update comment
            update_notes = f"Manually {action}d by admin. " + (notes if notes else "")
            cursor.execute('''
                UPDATE comments 
                SET status = ?, reviewed_by = ?, reviewed_at = CURRENT_TIMESTAMP,
                    moderation_notes = ?
                WHERE comment_id = ?
            ''', (status, admin_id, update_notes, comment_id))
            
            # Log the action
            cursor.execute('''
                INSERT INTO moderation_log (comment_id, action, performed_by, notes)
                VALUES (?, ?, ?, ?)
            ''', (comment_id, f'manually_{action}', admin_id, update_notes))
            
            # Notify the user
            user_id = comment[6]
            if action == 'approve':
                self.add_notification(user_id, f"Your comment #{comment_id} has been approved by a moderator!", 'success')
            else:
                self.add_notification(user_id, f"Your comment #{comment_id} has been rejected by a moderator. Reason: {notes or 'Violates guidelines'}", 'error')
            
            # Save to training data for ML improvement
            cursor.execute('''
                INSERT INTO ml_training_data 
                (comment_text, language, is_abusive, is_spam, has_bad_links, final_status, human_reviewed)
                VALUES (?, ?, ?, ?, ?, ?, 1)
            ''', (
                comment[0],
                comment[5] if comment[5] else 'en',
                1 if action == 'reject' else 0,
                0 if action == 'approve' else 1,
                0,
                status
            ))
            
            conn.commit()
            conn.close()
            
            return {"success": True, "message": f"Comment {action}d successfully"}
            
        except sqlite3.OperationalError as e:
            if conn:
                conn.close()
            if "database is locked" in str(e):
                return {"success": False, "message": "Database is busy, please try again in a moment"}
            return {"success": False, "message": f"Database error: {str(e)}"}
        except Exception as e:
            if conn:
                conn.close()
            return {"success": False, "message": f"Error: {str(e)}"}
    
    def get_moderation_stats(self):
        """Get detailed moderation statistics"""
        conn = None
        try:
            conn = self.get_db_connection()
            cursor = conn.cursor()
            
            stats = {}
            
            # Comments by status
            cursor.execute('''
                SELECT status, COUNT(*) as count 
                FROM comments 
                GROUP BY status
            ''')
            rows = cursor.fetchall()
            stats['by_status'] = {row[0]: row[1] for row in rows}
            
            # Comments by language
            cursor.execute('''
                SELECT detected_language, COUNT(*) as count 
                FROM comments 
                GROUP BY detected_language
            ''')
            rows = cursor.fetchall()
            stats['by_language'] = {row[0]: row[1] for row in rows}
            
            # ML performance stats
            cursor.execute('''
                SELECT 
                    AVG(ml_score) as avg_ml_score,
                    AVG(abuse_score) as avg_abuse,
                    AVG(spam_score) as avg_spam,
                    AVG(confidence) as avg_confidence
                FROM comments
            ''')
            ml_stats = cursor.fetchone()
            stats['ml_performance'] = {
                'avg_ml_score': ml_stats[0] if ml_stats[0] else 0,
                'avg_abuse_score': ml_stats[1] if ml_stats[1] else 0,
                'avg_spam_score': ml_stats[2] if ml_stats[2] else 0,
                'avg_confidence': ml_stats[3] if ml_stats[3] else 0
            }
            
            # Link statistics
            cursor.execute('''
                SELECT 
                    SUM(link_count) as total_links,
                    SUM(has_malicious_links) as malicious_links
                FROM comments
            ''')
            link_stats = cursor.fetchone()
            stats['links'] = {
                'total_links': link_stats[0] or 0,
                'malicious_links': link_stats[1] or 0
            }
            
            # Recent moderation activity
            cursor.execute('''
                SELECT ml.action, u.username, ml.performed_at, ml.notes, c.comment_id,
                       c.ml_score, c.confidence
                FROM moderation_log ml
                JOIN users u ON ml.performed_by = u.user_id
                JOIN comments c ON ml.comment_id = c.comment_id
                ORDER BY ml.performed_at DESC
                LIMIT 10
            ''')
            rows = cursor.fetchall()
            stats['recent_activity'] = [
                {
                    'action': row[0],
                    'username': row[1],
                    'performed_at': row[2],
                    'notes': row[3],
                    'comment_id': row[4],
                    'ml_score': row[5],
                    'confidence': row[6]
                }
                for row in rows
            ]
            
            # User reputation stats
            cursor.execute('''
                SELECT 
                    AVG(reputation_score) as avg_reputation,
                    SUM(total_comments) as total_comments,
                    SUM(flagged_comments) as total_flagged,
                    COUNT(*) as total_users
                FROM users
            ''')
            user_stats = cursor.fetchone()
            stats['users'] = {
                'avg_reputation': user_stats[0] or 0,
                'total_comments': user_stats[1] or 0,
                'total_flagged': user_stats[2] or 0,
                'total_users': user_stats[3] or 0
            }
            
            # Phone validation stats
            cursor.execute('''
                SELECT 
                    COUNT(*) as total_users,
                    SUM(CASE WHEN phone IS NOT NULL THEN 1 ELSE 0 END) as users_with_phone
                FROM users
            ''')
            phone_stats = cursor.fetchone()
            stats['phone_stats'] = {
                'total_users': phone_stats[0] or 0,
                'users_with_phone': phone_stats[1] or 0,
                'phone_percentage': round((phone_stats[1] or 0) / phone_stats[0] * 100, 2) if phone_stats[0] and phone_stats[0] > 0 else 0
            }
            
            # Notification stats
            cursor.execute('''
                SELECT COUNT(*) FROM notifications WHERE is_read = 0
            ''')
            unread = cursor.fetchone()[0]
            stats['unread_notifications'] = unread or 0
            
            # Blocked domains
            cursor.execute('''
                SELECT domain, threat_level, added_at, reason
                FROM blocked_domains
                ORDER BY threat_level DESC
                LIMIT 10
            ''')
            rows = cursor.fetchall()
            stats['blocked_domains'] = [
                {
                    'domain': row[0],
                    'threat_level': row[1],
                    'added_at': row[2],
                    'reason': row[3]
                }
                for row in rows
            ]
            
            conn.close()
            return {"success": True, "stats": stats}
            
        except sqlite3.OperationalError as e:
            if conn:
                conn.close()
            if "database is locked" in str(e):
                return {"success": False, "message": "Database is busy, please try again in a moment"}
            return {"success": False, "message": f"Database error: {str(e)}"}
        except Exception as e:
            if conn:
                conn.close()
            return {"success": False, "message": f"Error: {str(e)}"}


# Initialize the ML system
moderator = MLCommentModerator()

# Authentication decorators
def login_required(f):
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if 'user_id' not in session:
            return jsonify({"success": False, "message": "Authentication required"}), 401
        return f(*args, **kwargs)
    return decorated_function

def admin_required(f):
    @wraps(f)
    def decorated_function(*args, **kwargs):
        if 'user_id' not in session:
            return jsonify({"success": False, "message": "Authentication required"}), 401
        if session.get('user_type') != 'admin':
            return jsonify({"success": False, "message": "Admin access required"}), 403
        return f(*args, **kwargs)
    return decorated_function


# ============= API ROUTES =============
@app.route('/api/register', methods=['POST'])
def register():
    """Register a new user with phone validation"""
    data = request.get_json()
    result = moderator.register_user(
        username=data.get('username'),
        password=data.get('password'),
        email=data.get('email'),
        full_name=data.get('full_name'),
        phone=data.get('phone'),
        user_type=data.get('user_type', 'member'),
        preferred_language=data.get('preferred_language', 'en')
    )
    return jsonify(result)

@app.route('/api/login', methods=['POST'])
def login():
    """Login user with welcome notification"""
    data = request.get_json()
    result = moderator.login_user(
        username=data.get('username'),
        password=data.get('password')
    )
    
    if result['success']:
        session['user_id'] = result['user']['user_id']
        session['username'] = result['user']['username']
        session['user_type'] = result['user']['user_type']
        session['full_name'] = result['user']['full_name']
    
    return jsonify(result)

@app.route('/api/logout', methods=['POST'])
def logout():
    """Logout user"""
    session.clear()
    return jsonify({"success": True, "message": "Logged out successfully"})

@app.route('/api/notifications', methods=['GET'])
@login_required
def get_notifications():
    """Get user notifications"""
    try:
        unread_only = request.args.get('unread_only', 'false').lower() == 'true'
        notifications = moderator.get_notifications(session['user_id'], unread_only)
        return jsonify({"success": True, "notifications": notifications})
    except Exception as e:
        return jsonify({"success": False, "message": str(e)}), 500

@app.route('/api/notifications/read', methods=['POST'])
@login_required
def mark_notifications_read():
    """Mark all notifications as read"""
    try:
        moderator.mark_notifications_read(session['user_id'])
        return jsonify({"success": True, "message": "Notifications marked as read"})
    except Exception as e:
        return jsonify({"success": False, "message": str(e)}), 500

@app.route('/api/validate-phone', methods=['POST'])
def validate_phone():
    """Validate a phone number"""
    try:
        data = request.get_json()
        phone = data.get('phone')
        if not phone:
            return jsonify({"success": False, "message": "Phone number required"}), 400
        result = moderator.validate_phone(phone)
        return jsonify(result)
    except Exception as e:
        return jsonify({"success": False, "message": str(e)}), 500

@app.route('/api/comments', methods=['POST'])
@login_required
def submit_comment():
    """Submit a new comment with ML moderation"""
    data = request.get_json()
    result = moderator.submit_comment(
        user_id=session['user_id'],
        comment_text=data.get('comment_text'),
        ip_address=request.remote_addr,
        user_agent=request.headers.get('User-Agent')
    )
    return jsonify(result)

@app.route('/api/comments', methods=['GET'])
@login_required
def get_comments():
    """Get comments"""
    status = request.args.get('status')
    limit = request.args.get('limit', 50, type=int)
    
    result = moderator.get_comments(
        user_id=session['user_id'],
        user_type=session['user_type'],
        status=status,
        limit=limit
    )
    return jsonify(result)

@app.route('/api/comments/<int:comment_id>/moderate', methods=['POST'])
@admin_required
def moderate_comment(comment_id):
    """Moderate a comment (admin only)"""
    data = request.get_json()
    result = moderator.moderate_comment(
        comment_id=comment_id,
        admin_id=session['user_id'],
        action=data.get('action'),
        notes=data.get('notes')
    )
    return jsonify(result)

@app.route('/api/comments/pending', methods=['GET'])
@admin_required
def get_pending_comments():
    """Get pending comments (admin only)"""
    result = moderator.get_comments(
        user_type='admin',
        status='under_review'
    )
    return jsonify(result)

@app.route('/api/stats', methods=['GET'])
@admin_required
def get_stats():
    """Get moderation statistics (admin only)"""
    result = moderator.get_moderation_stats()
    return jsonify(result)

@app.route('/api/blocked-domains', methods=['GET'])
@admin_required
def get_blocked_domains():
    """Get list of blocked domains"""
    conn = moderator.get_db_connection()
    cursor = conn.cursor()
    cursor.execute('''
        SELECT domain, threat_level, reason, added_at
        FROM blocked_domains
        ORDER BY threat_level DESC
    ''')
    rows = cursor.fetchall()
    domains = [
        {'domain': row[0], 'threat_level': row[1], 'reason': row[2], 'added_at': row[3]}
        for row in rows
    ]
    conn.close()
    return jsonify({"success": True, "domains": domains})

@app.route('/api/blocked-domains', methods=['POST'])
@admin_required
def add_blocked_domain():
    """Add a new blocked domain"""
    data = request.get_json()
    domain = data.get('domain')
    threat_level = data.get('threat_level', 'medium')
    reason = data.get('reason', '')
    
    conn = moderator.get_db_connection()
    cursor = conn.cursor()
    try:
        cursor.execute('''
            INSERT INTO blocked_domains (domain, threat_level, added_by, reason)
            VALUES (?, ?, ?, ?)
        ''', (domain, threat_level, session['user_id'], reason))
        conn.commit()
        result = {"success": True, "message": f"Domain {domain} added to blocklist"}
    except sqlite3.IntegrityError:
        result = {"success": False, "message": "Domain already exists"}
    finally:
        conn.close()
    
    return jsonify(result)

@app.route('/api/session', methods=['GET'])
def get_session():
    """Get current session info"""
    if 'user_id' in session:
        return jsonify({
            "success": True,
            "authenticated": True,
            "user": {
                "user_id": session['user_id'],
                "username": session['username'],
                "user_type": session['user_type'],
                "full_name": session['full_name']
            }
        })
    return jsonify({
        "success": True,
        "authenticated": False
    })

