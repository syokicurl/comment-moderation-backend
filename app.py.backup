    def get_db_connection(self):
        """Get database connection with timeout and WAL mode"""
        return get_db_connection(self.db_name)
    
    def setup_database(self):
        """Create database tables"""
        conn = self.get_db_connection()
        cursor = conn.cursor()
        
        # Users table with phone number
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS users (
                user_id INTEGER PRIMARY KEY AUTOINCREMENT,
                username TEXT UNIQUE NOT NULL,
                password TEXT NOT NULL,
                email TEXT UNIQUE NOT NULL,
                full_name TEXT,
                phone TEXT UNIQUE,
                country_code TEXT,
                user_type TEXT NOT NULL CHECK(user_type IN ('admin', 'member')),
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                last_login TIMESTAMP,
                is_active BOOLEAN DEFAULT 1,
                preferred_language TEXT DEFAULT 'en',
                reputation_score FLOAT DEFAULT 1.0,
                total_comments INTEGER DEFAULT 0,
                flagged_comments INTEGER DEFAULT 0,
                welcome_shown BOOLEAN DEFAULT 0
            )
        ''')
        
        # Comments table with ML scores
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS comments (
                comment_id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER NOT NULL,
                comment_text TEXT NOT NULL,
                cleaned_text TEXT,
                detected_language TEXT,
                ml_score FLOAT,
                abuse_score FLOAT,
                spam_score FLOAT,
                link_count INTEGER DEFAULT 0,
                has_malicious_links BOOLEAN DEFAULT 0,
                sentiment_score FLOAT,
                toxicity_score FLOAT,
                status TEXT DEFAULT 'under_review' 
                    CHECK(status IN ('approved', 'rejected', 'under_review', 'auto_approved', 'auto_rejected')),
                moderation_notes TEXT,
                ip_address TEXT,
                user_agent TEXT,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                reviewed_by INTEGER,
                reviewed_at TIMESTAMP,
                ml_model_version TEXT,
                confidence FLOAT,
                FOREIGN KEY (user_id) REFERENCES users(user_id),
                FOREIGN KEY (reviewed_by) REFERENCES users(user_id)
            )
        ''')
        
        # ML Training data table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS ml_training_data (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                comment_text TEXT NOT NULL,
                cleaned_text TEXT,
                language TEXT,
                is_abusive BOOLEAN,
                is_spam BOOLEAN,
                has_bad_links BOOLEAN,
                final_status TEXT,
                human_reviewed BOOLEAN DEFAULT 0,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        
        # Moderation log table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS moderation_log (
                log_id INTEGER PRIMARY KEY AUTOINCREMENT,
                comment_id INTEGER,
                action TEXT,
                performed_by INTEGER,
                performed_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                ml_confidence FLOAT,
                notes TEXT,
                FOREIGN KEY (comment_id) REFERENCES comments(comment_id),
                FOREIGN KEY (performed_by) REFERENCES users(user_id)
            )
        ''')
        
        # Blocked domains/link table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS blocked_domains (
                domain_id INTEGER PRIMARY KEY AUTOINCREMENT,
                domain TEXT UNIQUE,
                threat_level TEXT CHECK(threat_level IN ('low', 'medium', 'high', 'critical')),
                added_by INTEGER,
                added_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                reason TEXT,
                FOREIGN KEY (added_by) REFERENCES users(user_id)
            )
        ''')
        
        # Notifications table
        cursor.execute('''
            CREATE TABLE IF NOT EXISTS notifications (
                notification_id INTEGER PRIMARY KEY AUTOINCREMENT,
                user_id INTEGER NOT NULL,
                message TEXT NOT NULL,
                type TEXT DEFAULT 'info',
                is_read BOOLEAN DEFAULT 0,
                created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (user_id) REFERENCES users(user_id)
            )
        ''')
        
        conn.commit()
        conn.close()
        
        # Create default admin
        self.create_default_admin()
        # Add sample blocked domains
        self.initialize_blocked_domains()
    
    def create_default_admin(self):
        """Create default admin account"""
        conn = self.get_db_connection()
        cursor = conn.cursor()
        
        cursor.execute("SELECT * FROM users WHERE username = 'admin'")
        if not cursor.fetchone():
            hashed_password = self.hash_password('admin123')
            cursor.execute('''
                INSERT INTO users (username, password, email, full_name, user_type, preferred_language)
                VALUES (?, ?, ?, ?, ?, ?)
            ''', ('admin', hashed_password, 'admin@example.com', 'System Admin', 'admin', 'en'))
            conn.commit()
            print("✅ Default admin created - Username: admin, Password: admin123")
        
        conn.close()
    
    def initialize_blocked_domains(self):
        """Initialize list of known malicious/spam domains"""
        blocked_domains = [
            ('spam.com', 'high', 'Known spam domain'),
            ('malicious.net', 'critical', 'Malware distribution'),
            ('phishing.org', 'critical', 'Phishing site'),
            ('scam.com', 'high', 'Scam website'),
            ('bit.ly', 'medium', 'URL shortener - often used for spam'),
            ('tinyurl.com', 'medium', 'URL shortener - often used for spam'),
            ('goo.gl', 'medium', 'URL shortener - often used for spam'),
            ('adf.ly', 'high', 'Known for malicious ads'),
            ('shortlink.to', 'medium', 'Suspicious shortlink service'),
            ('shorte.st', 'high', 'Known spam domain'),
            ('yourls.org', 'medium', 'URL shortener service'),
            ('ow.ly', 'medium', 'URL shortener'),
            ('is.gd', 'medium', 'URL shortener'),
            ('buff.ly', 'medium', 'URL shortener'),
            ('bit.do', 'medium', 'URL shortener'),
            ('mcaf.ee', 'medium', 'URL shortener'),
            ('t.co', 'medium', 'Twitter URL shortener'),
            ('fb.me', 'medium', 'Facebook URL shortener'),
            ('amzn.to', 'medium', 'Amazon URL shortener'),
        ]
        
        conn = self.get_db_connection()
        cursor = conn.cursor()
        
        for domain, threat_level, reason in blocked_domains:
            try:
                cursor.execute('''
                    INSERT OR IGNORE INTO blocked_domains (domain, threat_level, added_by, reason)
                    VALUES (?, ?, 1, ?)
                ''', (domain, threat_level, reason))
            except:
                pass
        
        conn.commit()
        conn.close()
    
    def hash_password(self, password):
        return hashlib.sha256(password.encode()).hexdigest()
    
    def verify_password(self, password, hashed):
        return self.hash_password(password) == hashed
    
    def validate_phone(self, phone):
        """Validate phone number with country code"""
        try:
            # Parse phone number
            parsed_number = phonenumbers.parse(phone, None)
            
            # Check if valid
            if not phonenumbers.is_valid_number(parsed_number):
                return {
                    'valid': False,
                    'message': 'Invalid phone number'
                }
            
            # Get country code and info
            country_code = str(parsed_number.country_code)
            country = phonenumbers.region_code_for_number(parsed_number)
            carrier_name = carrier.name_for_number(parsed_number, "en")
            timezones = timezone.time_zones_for_number(parsed_number)
            
            # Format number
            formatted = phonenumbers.format_number(
                parsed_number, 
                phonenumbers.PhoneNumberFormat.INTERNATIONAL
            )
            
            return {
                'valid': True,
                'phone': formatted,
                'country_code': f"+{country_code}",
                'country': country,
                'carrier': carrier_name,
                'timezones': list(timezones) if timezones else [],
                'national_number': str(parsed_number.national_number)
            }
        except Exception as e:
            return {
                'valid': False,
                'message': f'Invalid phone format: {str(e)}'
            }
    
    def setup_nlp_pipeline(self):
        """Setup NLP preprocessing pipeline"""
        self.stop_words = set()
        for lang in self.supported_languages:
            try:
                self.stop_words.update(set(stopwords.words(lang)))
            except:
                pass
        
        # Add common abusive patterns
        self.abusive_patterns = [
            r'\b(f+u+c+k+)\b', r'\b(s+h+i+t+)\b', r'\b(a+s+s+)\b',
            r'\b(b+i+t+c+h+)\b', r'\b(d+i+c+k+)\b', r'\b(p+u+s+s+y+)\b',
            r'\b(c+u+n+t+)\b', r'\b(n+i+g+g+a+)\b', r'\b(f+a+g+)\b',
            r'\b(r+e+t+a+r+d+)\b', r'\b(s+l+u+t+)\b', r'\b(w+h+o+r+e+)\b',
            r'\b(i+d+i+o+t+)\b', r'\b(m+o+r+o+n+)\b', r'\b(s+t+u+p+i+d+)\b',
            r'\b(d+u+m+b+)\b', r'\b(u+s+e+l+e+s+s+)\b', r'\b(w+o+r+t+h+l+e+s+s+)\b'
        ]
        
        # Link patterns
        self.link_pattern = re.compile(
            r'http[s]?://(?:[a-zA-Z]|[0-9]|[$-_@.&+]|[!*\(\),]|(?:%[0-9a-fA-F][0-9a-fA-F]))+'
        )
    
    def initialize_ml_models(self):
        """Initialize or load ML models"""
        model_path = 'models/'
        os.makedirs(model_path, exist_ok=True)
        
        # Try to load existing models
        try:
            self.abuse_classifier = joblib.load(f'{model_path}abuse_classifier.pkl')
            self.link_classifier = joblib.load(f'{model_path}link_classifier.pkl')
            self.vectorizer = joblib.load(f'{model_path}vectorizer.pkl')
            print("✅ ML models loaded from disk")
        except:
            print("🔄 Training new ML models with sample data...")
            self.train_initial_models()
    
